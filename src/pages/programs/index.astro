---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionNav from "../../components/SectionNav.astro";

const programs = await getCollection("programs");
// Sort by order field
const sortedPrograms = programs.sort(
  (a, b) => (a.data.order || 99) - (b.data.order || 99),
);

const base = import.meta.env.BASE_URL;

const programLinks = [
  { label: "Overview", href: `${base}programs` },
  { label: "Free Consultation", href: `${base}programs/free-first-consultation` },
  { label: "Splints I Use", href: `${base}programs/the-splint` },
  { label: "Program Option 1", href: `${base}programs/program-option-1` },
  { label: "Program Option 2", href: `${base}programs/program-option-2` },
  { label: "Coping Options", href: `${base}programs/coping-without-retraining` },
];
---

<Layout title="Programs" currentPath="/programs">
  <SectionNav links={programLinks} />

  <article>
    <h1>Retraining Programs & Support</h1>
    <p>
      I offer several options to help musicians retrain their motor control,
      manage symptoms, and design orthotics to bypass focal hand dystonia
      blocks.
    </p>

    <h2>Options & Resources</h2>
    <div class="card-grid">
      {
        sortedPrograms.map((program) => (
          <a href={`${base}programs/${program.id}`} class="card">
            <h3>{program.data.title}</h3>
            <p>{program.data.description}</p>
          </a>
        ))
      }
    </div>
  </article>
</Layout>
