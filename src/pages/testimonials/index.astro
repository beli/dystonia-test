---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionNav from "../../components/SectionNav.astro";

const testimonials = await getCollection("testimonials");

const base = import.meta.env.BASE_URL;

const testimonialLinks = [
  { label: "Overview", href: `${base}testimonials` },
  {
    label: "Right Hand Index Finger",
    href: `${base}testimonials/classical-guitarist-index-finger-fd`,
  },
  {
    label: "Left Fretting Hand",
    href: `${base}testimonials/guitarist-left-fretting-hand-dystonia`,
  },
  {
    label: "Fretting Hand Recovery",
    href: `${base}testimonials/guitarist-fretting-hand-dystonia-recovery`,
  },
];
---

<Layout title="Testimonials" currentPath="/testimonials">
  <SectionNav links={testimonialLinks} />

  <article>
    <h1>Testimonials & Case Studies</h1>
    <p>
      Read about the experiences of professional and advanced musicians who have
      undergone focal hand dystonia retraining under my guidance.
    </p>

    <h2>Individual Stories</h2>
    <div class="card-grid">
      {
        testimonials.map((testimonial) => (
          <a href={`${base}testimonials/${testimonial.id}`} class="card">
            <h3>{testimonial.data.title}</h3>
            <p>{testimonial.data.description}</p>
          </a>
        ))
      }
    </div>
  </article>
</Layout>
