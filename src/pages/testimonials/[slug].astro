---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionNav from "../../components/SectionNav.astro";
import { getSectionNavigation } from "../../utils/navigation";

export async function getStaticPaths() {
  const entries = await getCollection("testimonials");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const base = import.meta.env.BASE_URL;

const { links: testimonialLinks } = await getSectionNavigation('testimonials', entry.id, `${base}testimonials`, true);
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  currentPath="/testimonials"
>
  <SectionNav links={testimonialLinks} />

  <article>
    <h1>{entry.data.title}</h1>
    <Content />

    <div style="margin-top: 2.5rem; display: flex; gap: 1rem;">
      <a href={`${base}testimonials`} class="btn btn-secondary"
        >&larr; Back to Testimonials</a
      >
      <a href={`${base}contact`} class="btn">Start Your Recovery Journey</a>
    </div>
  </article>
</Layout>
